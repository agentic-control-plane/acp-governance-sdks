# ── ACP credentials ──────────────────────────────────────────────────
# Get yours: cloud.agenticcontrolplane.com → Settings → API Keys
# Format: gsk_<tenant-slug>_<random>
ACP_USER_TOKEN=gsk_your-slug_replace-me
ACP_GATEWAY_URL=https://api.agenticcontrolplane.com

# ── LLM provider (bring your own) ────────────────────────────────────
# Using @ai-sdk/anthropic by default. Swap the import in starter.ts for
# @ai-sdk/openai / @ai-sdk/google if you'd rather, and set the matching key.
ANTHROPIC_API_KEY=sk-ant-replace-me
