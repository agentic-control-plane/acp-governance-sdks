# ── ACP credentials ──────────────────────────────────────────────────
# Get yours: cloud.agenticcontrolplane.com → Settings → API Keys
# Format: gsk_<tenant-slug>_<random>
ACP_USER_TOKEN=gsk_your-slug_replace-me
ACP_GATEWAY_URL=https://api.agenticcontrolplane.com

# ── LLM provider (Pydantic AI reads this directly based on the model string) ──
# Swap to OPENAI_API_KEY / GEMINI_API_KEY if you change the model prefix
# in starter.py (e.g. "openai:gpt-4o-mini" → needs OPENAI_API_KEY).
ANTHROPIC_API_KEY=sk-ant-replace-me
