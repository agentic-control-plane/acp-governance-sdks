# ── ACP credentials ──────────────────────────────────────────────────
# Get yours: cloud.agenticcontrolplane.com → Settings → API Keys
# Format: gsk_<tenant-slug>_<random>
ACP_USER_TOKEN=gsk_your-slug_replace-me
ACP_GATEWAY_URL=https://api.agenticcontrolplane.com

# ── LLM provider (Gemini via Google AI Studio) ──────────────────────
# For direct Gemini API usage (simplest BYOK). Swap to ADC / Vertex AI
# by setting GOOGLE_GENAI_USE_VERTEXAI=True + GOOGLE_CLOUD_PROJECT.
GOOGLE_API_KEY=AIza-replace-me
GOOGLE_GENAI_USE_VERTEXAI=False
