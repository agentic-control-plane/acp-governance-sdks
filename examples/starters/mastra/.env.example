# ── ACP credentials ──────────────────────────────────────────────────
# Get yours: cloud.agenticcontrolplane.com → Settings → API Keys
# Format: gsk_<tenant-slug>_<random>
ACP_USER_TOKEN=gsk_your-slug_replace-me
ACP_GATEWAY_URL=https://api.agenticcontrolplane.com

# ── LLM provider (Mastra's model router resolves the prefix) ─────────
# Using 'openai/gpt-4o-mini' by default. Swap to 'anthropic/claude-sonnet-4-6'
# or 'google/gemini-*' in starter.ts — match the key to your choice.
OPENAI_API_KEY=sk-proj-replace-me
