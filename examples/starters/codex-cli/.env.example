# ── ACP credentials ──────────────────────────────────────────────────
# Get yours: cloud.agenticcontrolplane.com → Settings → API Keys
# Format: gsk_<tenant-slug>_<random>
ACP_USER_TOKEN=gsk_your-slug_replace-me
ACP_GATEWAY_URL=https://api.agenticcontrolplane.com

# Codex CLI manages its own OpenAI auth via `codex login` — no
# OPENAI_API_KEY needed here.
