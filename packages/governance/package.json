{
  "name": "@agenticcontrolplane/governance",
  "version": "0.2.0",
  "description": "Thin Node SDK for the Agentic Control Plane governance hook protocol. Wrap any tool call; ACP decides allow/deny/redact.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/davidcrowe/acp-governance-sdks",
    "directory": "packages/governance"
  },
  "homepage": "https://agenticcontrolplane.com",
  "keywords": [
    "agentic-control-plane",
    "acp",
    "agent-governance",
    "tool-call-audit",
    "delegation-chain"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
